# Copy this file to .env and fill in values for local development.
# .env is gitignored and never committed.
#
# For AWS environments, these are set as ECS task environment variables.
# The ANTHROPIC_API_KEY is fetched from SSM Parameter Store at startup
# using SSM_API_KEY_PARAM — do not hardcode it here.

# AWS configuration
AWS_REGION=eu-central-1
AWS_PROFILE=dev-admin

# Platform environment (dev | staging | prod)
ENVIRONMENT=dev

# S3 bucket names (replace ACCOUNT_ID with your 12-digit account ID)
BRONZE_BUCKET=edp-dev-ACCOUNT_ID-bronze
GOLD_BUCKET=edp-dev-ACCOUNT_ID-gold
ATHENA_RESULTS_BUCKET=edp-dev-ACCOUNT_ID-athena-results

# Athena configuration
ATHENA_WORKGROUP=edp-dev-workgroup

# Glue catalog Gold database name
GLUE_GOLD_DATABASE=edp_dev_gold

# SSM parameter name for the Anthropic API key
# The agent fetches this at startup and never logs or exposes the value.
SSM_API_KEY_PARAM=/edp/dev/anthropic_api_key

# Cost guardrail: maximum USD per query before the agent refuses to execute.
# The Athena WorkGroup bytes_scanned_cutoff_per_query is the hard AWS-level backstop.
# This is a soft application-level check for the audit log.
COST_THRESHOLD_USD=0.10

# Maximum rows returned per query (injected as LIMIT if missing from generated SQL)
MAX_ROWS=1000
